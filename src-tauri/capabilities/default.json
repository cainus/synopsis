{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl/capability.schema.json",
  "identifier": "default",
  "description": "Default capabilities for synopsis",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn"
  ]
}
